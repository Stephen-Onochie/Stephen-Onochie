# Supabase URL and anon key (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Only this Google account can access /apps (must match Supabase Google sign-in email)
ALLOWED_EMAIL=stephenconochie@gmail.com

# StyleMate: Gemini Vision for clothing photo tagging (server-only)
GEMINI_API_KEY=

# Native Clock (optional — defaults to West Lafayette, IN; NPR top stories RSS)
# NATIVE_CLOCK_LAT=40.4259
# NATIVE_CLOCK_LON=-86.9081
# NATIVE_CLOCK_LOCATION=West Lafayette
# NATIVE_CLOCK_NEWS_FEED=https://feeds.npr.org/1001/rss.xml

# --- StyleMate Supabase setup ---
# 1. Run supabase/migrations/20260526000000_create_stylemate_tables.sql
#    (creates wardrobe_items table, enums, RLS, and wardrobe-images storage bucket)
# 2. Add GEMINI_API_KEY locally and in Vercel project settings

# --- Supabase Auth setup (required for Google OAuth) ---
# 1. Supabase Dashboard > Authentication > Providers > Google: enable + add Google Client ID/Secret
# 2. Google Cloud Console authorized redirect URI:
#    https://<project-ref>.supabase.co/auth/v1/callback
# 3. Supabase Dashboard > Authentication > URL Configuration:
#    Site URL: https://stephenonochie.com
#    Redirect URLs (add every domain you use):
#      http://localhost:3000/auth/callback
#      https://stephenonochie.com/auth/callback
#      https://www.stephenonochie.com/auth/callback
#      https://personal-website-rouge-six-61.vercel.app/auth/callback
# 4. Set all three env vars above in Vercel (ALLOWED_EMAIL is server-only)
